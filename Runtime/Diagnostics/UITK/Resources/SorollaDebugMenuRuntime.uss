/* Runtime-safe design tokens for the UI Toolkit debug menu overlay (spike, phase 1). Values are
   the EXACT tokens from the approved design source (Claude Design "Sorolla Vitals Mobile.dc.html"),
   distilled in sorolla-docs platform/sdk/research/debug-menu-mockups-2026-07/design-tokens.md -
   these supersede the earlier "seed from editor tokens.uss" placeholder colors; the editor sheet
   is expected to converge toward these later, not the other way around. This sheet is deliberately
   standalone: it must load and render with zero project setup, so it does not @import the editor
   stylesheet (which lives outside any Resources folder and is not guaranteed to ship at runtime).
   Phase 1 only wires the shell/header/tabs; row/badge/console/action tokens below are captured
   now (verbatim from the token doc) so phase 2+ can consume them without re-deriving values. */

/* NOT position:absolute here: this class is applied to UIDocument.rootVisualElement itself,
   which UI Toolkit already stretches to fill the panel by default (100% width/height, no
   positioned ancestor to resolve offsets against). Overriding it to absolute produced a NaN-sized
   layout (confirmed via execute_script inspection: root resolvedStyle was NaNxNaN, hence the
   blank screenshot during the first verification pass) - explicit 100%/flex column is the fix. */
.sorolla-debugmenu-root {
    width: 100%;
    height: 100%;
    flex-direction: column;
    background-color: rgb(13, 15, 19); /* shell #0d0f13 */
}

.sorolla-debugmenu-header {
    background-color: rgb(18, 21, 28); /* section header bg #141922, close enough for header band */
    padding: 10px 16px 8px 16px;
    border-bottom-width: 1px;
    border-bottom-color: rgb(28, 34, 44); /* #1c222c neutral row border */
}

/* Vertical rhythm between header blocks tightened to ~8-9px at reference scale (team-lead tier-2
   ruling): the header was reading ~31% of screen height vs the mockup's ~22%, and stacked
   margin-bottoms across 5 blocks (badge row / count strip / context / coverage) compounded past
   the mockup's tighter spacing. */
.sorolla-debugmenu-header-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
}

.sorolla-debugmenu-title {
    font-size: 12px; /* "Sorolla Vitals" label token: 12px */
    -unity-font-style: bold;
    color: rgb(106, 116, 132); /* #6a7484 */
    flex-grow: 1;
}

.sorolla-debugmenu-close {
    background-color: rgb(23, 29, 39); /* normal action bg #171d27 */
    color: rgb(211, 218, 228); /* normal action fg #d3dae4 */
    border-width: 1px;
    border-color: rgb(36, 45, 58); /* #242d3a */
    border-radius: 6px;
    padding: 4px 12px;
    font-size: 12px;
    -unity-font-style: bold;
}

.sorolla-debugmenu-close:hover {
    background-color: rgb(28, 33, 44);
}

/* Verdict badge: 9px dot + 15px/800 word, padding 7x14, radius 8, 1px border (token doc). Dot is a
   fixed-size rounded VisualElement added alongside the label, not a unicode glyph, so it renders
   identically across platforms. */
.sorolla-debugmenu-badge {
    flex-direction: row;
    align-items: center;
    border-radius: 8px;
    border-width: 1px;
    padding: 7px 14px;
    margin-right: 8px;
    align-self: flex-start;
}

.sorolla-debugmenu-badge-dot {
    width: 9px;
    height: 9px;
    border-radius: 5px;
    margin-right: 6px;
}

.sorolla-debugmenu-badge-label {
    font-size: 15px;
    -unity-font-style: bold;
}

.sorolla-debugmenu-badge-healthy { background-color: rgb(18, 40, 26); border-color: rgb(44, 107, 68); }
.sorolla-debugmenu-badge-healthy .sorolla-debugmenu-badge-label { color: rgb(126, 226, 164); }
.sorolla-debugmenu-badge-healthy .sorolla-debugmenu-badge-dot { background-color: rgb(63, 191, 114); }

.sorolla-debugmenu-badge-issues { background-color: rgb(46, 36, 16); border-color: rgb(122, 95, 34); }
.sorolla-debugmenu-badge-issues .sorolla-debugmenu-badge-label { color: rgb(243, 210, 122); }
.sorolla-debugmenu-badge-issues .sorolla-debugmenu-badge-dot { background-color: rgb(217, 166, 54); }

.sorolla-debugmenu-badge-failing { background-color: rgb(51, 21, 18); border-color: rgb(138, 58, 50); }
.sorolla-debugmenu-badge-failing .sorolla-debugmenu-badge-label { color: rgb(255, 157, 148); }
.sorolla-debugmenu-badge-failing .sorolla-debugmenu-badge-dot { background-color: rgb(224, 88, 79); }

/* width:100% + white-space:normal (not just one or the other) - a Label with no explicit width
   sizes to its own intrinsic (unwrapped) text width in some UITK layouts regardless of white-space,
   so wrapping never kicks in without an explicit width to wrap against. Found live at 1920x1080
   (context/coverage text overflowing the panel edge instead of wrapping) even after white-space
   alone was set. */
.sorolla-debugmenu-context-line {
    font-size: 11px;
    color: rgb(111, 122, 138); /* header context line #6f7a8a */
    margin-bottom: 2px;
    white-space: normal;
    width: 100%;
}

/* COVERAGE caption + sentence render INLINE on one row (team-lead tier-2 ruling, matches the
   design source): the caption is a fixed-width label on the left, the sentence flows to its right
   and may wrap to a second line under itself - not a separate stacked line. Stacking them was the
   single biggest contributor to the header's oversized vertical footprint. */
.sorolla-debugmenu-coverage-row {
    flex-direction: row;
    align-items: flex-start;
}

.sorolla-debugmenu-coverage-caption {
    font-size: 9.5px;
    -unity-font-style: bold;
    letter-spacing: 0.4px;
    color: rgb(125, 134, 148);
    flex-shrink: 0;
    margin-right: 6px;
    margin-top: 1px; /* nudges the small-caps caption toward the sentence's cap-height baseline */
}

/* Coverage sentence: #7d8694 normal, amber #d9a636 when coverage is thin (design-tokens.md
   COVERAGE). white-space normal + flex-grow/shrink so it wraps to a second line within the
   remaining row width instead of overflowing the panel edge (found in visual QA against mockup 01). */
.sorolla-debugmenu-coverage-line {
    font-size: 11px;
    color: rgb(125, 134, 148);
    white-space: normal;
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
}

.sorolla-debugmenu-coverage-line-thin {
    color: rgb(217, 166, 54); /* #d9a636 */
}

/* Severity count strip (header, spec 2.1.2). Colored counts: FAIL #ff9d94, WARN #f3d27a,
   WAIT #9db8d2, PASS #7ee2a4; zero-count severities grey to #525c6b (PASS always colored). */
.sorolla-debugmenu-countstrip {
    flex-direction: row;
    margin-bottom: 6px;
}

.sorolla-debugmenu-countstrip-item {
    font-size: 12px;
    -unity-font-style: bold;
    margin-right: 12px;
}

.sorolla-debugmenu-count-fail { color: rgb(255, 157, 148); }
.sorolla-debugmenu-count-warn { color: rgb(243, 210, 122); }
.sorolla-debugmenu-count-wait { color: rgb(157, 184, 210); }
.sorolla-debugmenu-count-pass { color: rgb(126, 226, 164); }
.sorolla-debugmenu-count-zero { color: rgb(82, 92, 107); } /* #525c6b */

.sorolla-debugmenu-tabs {
    flex-direction: row;
}

/* Tabs & accents token block: active bg #1c5b63 / fg #dffafd / border #2a7a85, radius 8 8 0 0,
   underline #2a5a63; inactive bg #12151c / fg #7d8694 / border #1c222c. */
.sorolla-debugmenu-tab {
    flex-grow: 1;
    background-color: rgb(18, 21, 28); /* #12151c */
    color: rgb(125, 134, 148); /* #7d8694 */
    border-width: 1px;
    border-color: rgb(28, 34, 44); /* #1c222c */
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    padding: 8px 4px;
    font-size: 12px;
    -unity-font-style: bold;
    margin-right: 1px;
}

.sorolla-debugmenu-tab:hover {
    background-color: rgb(24, 29, 38);
}

.sorolla-debugmenu-tab-active {
    background-color: rgb(28, 91, 99); /* #1c5b63 */
    color: rgb(223, 250, 253); /* #dffafd */
    border-color: rgb(42, 122, 133); /* #2a7a85 */
    border-bottom-width: 2px;
    border-bottom-color: rgb(42, 90, 99); /* underline #2a5a63 */
}

.sorolla-debugmenu-content {
    flex-grow: 1;
    padding: 16px;
}

.sorolla-debugmenu-placeholder {
    font-size: 12px;
    color: rgb(125, 134, 148); /* #7d8694 */
}

/* ---- Issues tab (phase 2): mockups 01/02, spec 2.2 + section 3 ---- */

.sorolla-debugmenu-issues-pane {
    flex-grow: 1;
    flex-direction: column;
}

/* padding-right reserves a gutter so the vertical scrollbar (drawn inside the ScrollView's own
   box) doesn't sit on top of row text - found via visual QA against mockup 01, where row detail
   ran under the scrollbar thumb. */
.sorolla-debugmenu-issues-scroll {
    flex-grow: 1;
    padding-right: 14px;
}

/* No default widget chrome may survive (standing rule): the default UITK vertical scroller reads
   as an unfinished desktop-app scrollbar (thick track, arrow buttons, grey chrome). Restyled to a
   thin token-colored thumb with no track/arrows, matching the design source's own scrollbar spec. */
.sorolla-debugmenu-issues-scroll .unity-scroller--vertical {
    width: 8px;
}

.sorolla-debugmenu-issues-scroll .unity-scroller__low-button,
.sorolla-debugmenu-issues-scroll .unity-scroller__high-button {
    display: none;
}

.sorolla-debugmenu-issues-scroll .unity-scroller--vertical .unity-base-slider__tracker {
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
}

.sorolla-debugmenu-issues-scroll .unity-scroller--vertical .unity-base-slider__dragger {
    background-color: rgb(58, 63, 72); /* #3a3f48 */
    border-radius: 6px;
    width: 6px;
}

/* Row skins by severity (design-tokens.md): FAIL #1d1210/#4a2620, WARN #1c1810/#463a1c,
   neutral (WAIT/other) #12151c/#1c222c. */
.sorolla-debugmenu-issue-row {
    border-radius: 8px;
    border-width: 1px;
    margin-bottom: 6px;
    overflow: hidden;
}

.sorolla-debugmenu-row-fail { background-color: rgb(29, 18, 16); border-color: rgb(74, 38, 32); }
.sorolla-debugmenu-row-warn { background-color: rgb(28, 24, 16); border-color: rgb(70, 58, 28); }
.sorolla-debugmenu-row-neutral { background-color: rgb(18, 21, 28); border-color: rgb(28, 34, 44); }

.sorolla-debugmenu-issue-row-collapsed {
    flex-direction: row;
    align-items: center;
    min-height: 44px;
    padding: 6px 10px;
}

/* Severity badge: bg/fg per design-tokens.md (FAIL/WARN/WAIT/PASS/INFO). Square radius 5px. */
.sorolla-debugmenu-severity-badge {
    font-size: 10px;
    -unity-font-style: bold;
    letter-spacing: 0.5px;
    border-radius: 5px;
    padding: 3px 6px;
    margin-right: 8px;
    min-width: 40px;
    -unity-text-align: middle-center;
}

.sorolla-debugmenu-badge-fail { background-color: rgb(201, 71, 62); color: rgb(255, 255, 255); }
.sorolla-debugmenu-badge-warn { background-color: rgb(217, 166, 54); color: rgb(36, 26, 4); }
.sorolla-debugmenu-badge-wait { background-color: rgb(65, 88, 110); color: rgb(211, 226, 242); }
.sorolla-debugmenu-badge-pass { background-color: rgb(47, 122, 76); color: rgb(230, 246, 236); }
.sorolla-debugmenu-badge-info { background-color: rgb(51, 58, 68); color: rgb(154, 165, 179); }

.sorolla-debugmenu-issue-name {
    font-size: 13px;
    -unity-font-style: bold;
    color: rgb(211, 218, 228);
    margin-right: 8px;
}

/* Ellipsis truncation needs all three of these (UITK, not one shorthand); flex-shrink + min-width:0
   is required or a flex child never shrinks below its text's natural width and overflow/ellipsis
   never kicks in - found via visual QA against mockup 01, where the old `flex-grow:1` alone let
   long detail strings run under the chevron/scrollbar instead of eliding. */
.sorolla-debugmenu-issue-detail {
    font-size: 11px;
    color: rgb(125, 134, 148);
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.sorolla-debugmenu-issue-chevron {
    font-size: 15px;
    color: rgb(125, 134, 148);
}

/* Expanded WHY/SIGNAL/FIX block (design-tokens.md "Diagnosis expansion"): 46px key column,
   WHY #ff9d94, SIGNAL #9db8d2, FIX #7ee2a4, value text 12px/#c6cdd8. */
.sorolla-debugmenu-diagnosis {
    padding: 4px 10px 10px 10px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
}

.sorolla-debugmenu-diagnosis-line {
    flex-direction: row;
    margin-top: 6px;
}

.sorolla-debugmenu-diagnosis-key {
    width: 46px;
    font-size: 9.5px;
    -unity-font-style: bold;
    letter-spacing: 0.6px;
    flex-shrink: 0;
}

.sorolla-debugmenu-diagnosis-why { color: rgb(255, 157, 148); }
.sorolla-debugmenu-diagnosis-signal { color: rgb(157, 184, 210); }
.sorolla-debugmenu-diagnosis-fix { color: rgb(126, 226, 164); }

.sorolla-debugmenu-diagnosis-value {
    font-size: 12px;
    color: rgb(198, 205, 216); /* #c6cdd8 */
    white-space: normal;
    flex-grow: 1;
    flex-shrink: 1;
}

/* ---- Empty state (Issues, zero problems) ---- */

.sorolla-debugmenu-empty-card {
    background-color: rgb(16, 25, 15); /* #10190f */
    border-color: rgb(30, 58, 42); /* #1e3a2a */
    border-width: 1px;
    border-radius: 12px;
    padding: 20px 16px;
    align-items: center;
}

.sorolla-debugmenu-empty-check {
    width: 40px;
    height: 40px;
    background-color: rgb(20, 58, 36); /* #143a24 */
    border-color: rgb(44, 107, 68); /* #2c6b44 */
    border-width: 1px;
    border-radius: 20px;
    color: rgb(126, 226, 164); /* #7ee2a4 */
    font-size: 18px;
    -unity-text-align: middle-center;
    margin-bottom: 10px;
}

.sorolla-debugmenu-empty-title {
    font-size: 14px;
    -unity-font-style: bold;
    color: rgb(207, 232, 214); /* #cfe8d6 */
    margin-bottom: 10px;
}

/* ---- Notes / callouts (info + warn) ---- */

.sorolla-debugmenu-note {
    font-size: 11px;
    white-space: normal;
    border-width: 1px;
    border-radius: 8px;
    padding: 8px 10px;
    margin-top: 8px;
}

.sorolla-debugmenu-note-info {
    background-color: rgb(20, 25, 34); /* #141922 */
    border-color: rgb(36, 45, 58); /* #242d3a */
    color: rgb(154, 166, 182); /* #9aa6b6 */
}

.sorolla-debugmenu-note-warn {
    background-color: rgb(36, 29, 16); /* #241d10 */
    border-color: rgb(90, 74, 36); /* #5a4a24 */
    color: rgb(215, 192, 140); /* #d7c08c */
}

/* ---- Buttons (Copy diagnosis / Copy problems) ---- */

.sorolla-debugmenu-action-button {
    border-radius: 9px;
    border-width: 1px;
    padding: 8px 14px;
    font-size: 12px;
    -unity-font-style: bold;
    margin-top: 8px;
}

.sorolla-debugmenu-action-button-primary {
    background-color: rgb(28, 91, 99); /* #1c5b63 */
    border-color: rgb(42, 122, 133); /* #2a7a85 */
    color: rgb(223, 250, 253); /* #dffafd */
    margin: 8px 10px;
}

.sorolla-debugmenu-action-button-ghost {
    background-color: rgba(0, 0, 0, 0);
    border-color: rgb(42, 49, 60); /* #2a313c */
    color: rgb(154, 165, 182); /* #9aa5b6 */
    align-self: flex-start;
}

/* ---- Overview tab (phase 3): mockup 03, spec 2.3 ---- */

.sorolla-debugmenu-overview-pane {
    flex-grow: 1;
    flex-direction: column;
}

.sorolla-debugmenu-filter-row {
    flex-direction: row;
    flex-wrap: wrap;
    margin-bottom: 10px;
}

/* Filter chips: active = active-tab skin, inactive = inactive-tab skin (design-tokens.md). */
.sorolla-debugmenu-filter-chip {
    background-color: rgb(18, 21, 28); /* inactive #12151c */
    color: rgb(125, 134, 148); /* #7d8694 */
    border-width: 1px;
    border-color: rgb(28, 34, 44); /* #1c222c */
    border-radius: 7px;
    padding: 7px 12px;
    font-size: 11px;
    -unity-font-style: bold;
    margin-right: 6px;
    margin-bottom: 6px;
}

.sorolla-debugmenu-filter-chip-active {
    background-color: rgb(28, 91, 99); /* #1c5b63 */
    color: rgb(223, 250, 253); /* #dffafd */
    border-color: rgb(42, 122, 133); /* #2a7a85 */
}

.sorolla-debugmenu-section {
    margin-bottom: 8px;
}

/* Section header: bg #141922, border #1d2430, title 12px/800 #b9c3d2, count mono 10.5px. */
.sorolla-debugmenu-section-header {
    flex-direction: row;
    align-items: center;
    background-color: rgb(20, 25, 34);
    border-width: 1px;
    border-color: rgb(29, 36, 48);
    border-radius: 8px;
    padding: 8px 10px;
    min-height: 36px;
}

.sorolla-debugmenu-section-chevron {
    font-size: 13px;
    color: rgb(125, 134, 148);
    margin-right: 6px;
}

.sorolla-debugmenu-section-title {
    font-size: 12px;
    -unity-font-style: bold;
    color: rgb(185, 195, 210); /* #b9c3d2 */
    flex-grow: 1;
}

.sorolla-debugmenu-section-count {
    font-size: 10.5px;
    -unity-font-style: bold;
}

.sorolla-debugmenu-section-count-warn { color: rgb(217, 166, 54); } /* CTXT.WARN */
.sorolla-debugmenu-section-count-clean { color: rgb(95, 138, 110); } /* #5f8a6e */

.sorolla-debugmenu-section-body {
    padding-top: 6px;
    padding-left: 10px; /* child rows indented 10px, design-tokens.md */
}

.sorolla-debugmenu-section-child-row {
    margin-bottom: 4px;
}

/* ---- Console tab (phase 3): mockup 04, spec 2.4 ---- */

.sorolla-debugmenu-console-pane {
    flex-grow: 1;
    flex-direction: column;
}

.sorolla-debugmenu-console-toolbar {
    flex-direction: row;
    align-items: center;
    margin-bottom: 10px;
}

.sorolla-debugmenu-console-summary {
    font-size: 11px;
    color: rgb(125, 134, 148); /* #7d8694 */
    flex-grow: 1;
}

.sorolla-debugmenu-console-controls {
    flex-direction: row;
    align-items: center;
}

.sorolla-debugmenu-console-toggle {
    font-size: 11px;
    color: rgb(125, 134, 148);
    margin-right: 8px;
}

/* No default widget chrome: strip the built-in Toggle checkbox texture, use a small token-colored
   box instead - same standing rule the Issues scrollbar restyle follows. */
.sorolla-debugmenu-console-toggle .unity-toggle__checkmark {
    width: 12px;
    height: 12px;
    border-width: 1px;
    border-color: rgb(66, 74, 88);
    background-color: rgb(18, 21, 28);
    border-radius: 3px;
}

.sorolla-debugmenu-console-toggle > .unity-toggle__input:checked .unity-toggle__checkmark {
    background-color: rgb(28, 91, 99); /* #1c5b63 */
    border-color: rgb(42, 122, 133); /* #2a7a85 */
}

.sorolla-debugmenu-console-toolbar-button {
    background-color: rgb(26, 33, 44); /* #1a212c */
    color: rgb(185, 195, 210); /* #b9c3d2 */
    border-width: 1px;
    border-color: rgb(36, 45, 58); /* #242d3a */
    border-radius: 7px;
    padding: 5px 12px;
    font-size: 11px;
    -unity-font-style: bold;
    margin-left: 6px;
}

.sorolla-debugmenu-console-row {
    border-radius: 8px;
    border-width: 1px;
    background-color: rgb(18, 21, 28); /* neutral row #12151c */
    border-color: rgb(28, 34, 44); /* #1c222c */
    margin-bottom: 6px;
    overflow: hidden;
}

.sorolla-debugmenu-console-row-collapsed {
    flex-direction: row;
    align-items: center;
    min-height: 44px;
    padding: 6px 10px;
}

.sorolla-debugmenu-console-row-title {
    font-size: 12.5px;
    -unity-font-style: bold;
    color: rgb(211, 218, 228); /* mono per token doc; no bundled mono font asset yet, default font */
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-left: 4px;
    margin-right: 8px;
}

.sorolla-debugmenu-console-payload {
    padding: 4px 10px 10px 10px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
}

/* Expanded payload key/value rows: bg #0e1219, key mono 11px #6f7a8a (108px column), value mono
   11px #cdd5e0 (design-tokens.md "Console"). */
.sorolla-debugmenu-console-payload-line {
    flex-direction: row;
    background-color: rgb(14, 18, 25);
    border-radius: 4px;
    padding: 3px 6px;
    margin-top: 3px;
}

.sorolla-debugmenu-console-payload-key {
    width: 108px;
    font-size: 11px;
    color: rgb(111, 122, 138); /* #6f7a8a */
    flex-shrink: 0;
}

.sorolla-debugmenu-console-payload-value {
    font-size: 11px;
    color: rgb(205, 213, 224); /* #cdd5e0 */
    white-space: normal;
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
}
